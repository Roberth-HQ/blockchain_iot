// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
}

model Gateway {
  id         String   @id @default(uuid())
  name       String?
  publicKey  String   @db.Text   // Clave pública para validar firma
  firmware   String?
  lastSeen   DateTime?
  createdAt  DateTime @default(now())

  devices    Device[]
}

model Device {
  id            String   @id @default(uuid())
  deviceId      String   @unique
  name          String?
  status        DeviceStatus @default(PENDING)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gatewayId   String?
  gateway     Gateway? @relation(fields: [gatewayId], references: [id])

  sensors     Sensor[]
  blockchainLogs BlockchainRecord[]
}

enum DeviceStatus {
  PENDING
  ACTIVE
  REVOKED
  SUSPENDED
}

model Sensor {
  id          String   @id @default(uuid())
  name        String?
  type        String        // temperature, humidity, gps, etc
  unit        String?       // °C, %, km/h
  minThreshold Float?
  maxThreshold Float?
  createdAt   DateTime @default(now())

  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id])

  readings    Reading[]
}


model Reading {
  id        String   @id @default(uuid())
  value     Float
  timestamp DateTime @default(now())
  hash      String?  @db.Text   // hash individual opcional

  sensorId  String
  sensor    Sensor   @relation(fields: [sensorId], references: [id])
}


model BlockchainRecord {
  id        String   @id @default(uuid())
  deviceId  String
  action    String   // REGISTER, BATCH_HASH, VERIFY, etc
  hash      String   @db.Text
  txHash    String?  // hash de transacción blockchain
  createdAt DateTime @default(now())

  device    Device   @relation(fields: [deviceId], references: [id])
}